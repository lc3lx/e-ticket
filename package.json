  "name": "e-ticket_back-end",
  "version": "1.0.0",
  "description": "A robust and comprehensive backend system for managing event ticket reservations, featuring detailed user role management, event categorization, real-time notifications, and an efficient complaint resolution mechanism. This system is optimized for scalability, security, and high concurrency, ensuring data integrity and a seamless user experience. Additionally, it is designed with future enhancements in mind, allowing for the integration of numerous innovative features beyond event ticket reservations.",
  "main": "server.js",
  "scripts": {
    "build": "npx tsc",
    "start": "nodemon dist/server.js",
    "start-server": "SET NODE_ENV=development&node dist/server.js",
    "start:prod": "SET NODE_ENV=production&nodemon -q dist/server.js",
    "dev": "concurrently \"npx tsc --watch\" \"nodemon -q dist/server.js\"",
    "test": "SET NODE_ENV=test&concurrently \"npx tsc --watch\" \"nodemon -q dist/server.js\"",
    "start:full": "set NODE_ENV=test&& npm run db:setup && concurrently \"npx tsc --watch\" \"nodemon -q dist/server.js\"",
    "migrate:generate": "npx sequelize-cli migration:generate --name",
    "migrate:run": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "db:drop": "npx sequelize-cli db:drop",
    "db:create": "npx sequelize-cli db:create",
    "db:seed:generate": "npx sequelize-cli seed:generate --name",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:setup": "powershell -Command \"if ($env:NODE_ENV) { $env:NODE_ENV } else { $env:NODE_ENV = 'test' }; npx sequelize-cli db:create; if ($LASTEXITCODE -ne 0) { echo 'Database already exists, proceeding to migrations...' }; npx sequelize-cli db:migrate\"",
    "db:reset": "npx sequelize-cli db:drop && npx sequelize-cli db:create && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
  },
  "keywords": [
    "express",
    "typescript",
    "postgresql",
    "sql",
    "sequelize",
    "orm",
    "sequelize-cli"
  ],
  "author": "Eng. Hazem Al-Shannan",
